# Copy to .env.local for local overrides (never commit .env.local).
#
# Vercel: Project → Settings → Environment Variables
# Add NEXT_PUBLIC_SITE_URL for Production (and Preview if you want stable OG/sitemap URLs):
#   https://boma.business.com
#
# Leave unset on Preview to use https://<deployment>.vercel.app automatically (VERCEL_URL).

# NEXT_PUBLIC_SITE_URL=https://boma.business.com
